        {
          "name": "canonical_class",
          "kind": "enum",
          "required": true,
          "help": "Ontology-backed layout class."
        },
        {
          "name": "bbox",
          "kind": "bbox4_normalized",
          "required": true,
          "validation": { "length": 4, "min": 0, "max": 1 }
        },
        { "name": "ro_index", "kind": "integer", "required": false },
        { "name": "attributes", "kind": "object", "required": false, "default": {} },
