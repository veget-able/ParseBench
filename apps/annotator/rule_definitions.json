      "category": "table",
      "ai_supported": false,
      "summary_fields": ["anchor_cell", "expected_neighbor", "page"],
      "fields": [
        { "name": "anchor_cell", "kind": "text", "required": true },
        { "name": "expected_neighbor", "kind": "text", "required": true },
        { "name": "table_anchor_cells", "kind": "string_array", "required": false, "default": [] }
      ]
    },
    {
      "type": "table_no_left",
